<mvc:View
    id="screen1View"
    controllerName="apptracciabilita.apptracciabilita.controller.Screen1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        id="page1"
        title="Fornitori">

        <customHeader>
            <Toolbar id="toolbar1">
                <Bar id="bar1">
                    <contentLeft>
                        <!-- <Image id="imageLogo1" src="IMG/Valentino.png" decorative="false" width="200px"/> -->
                        <Image id="imageLogo1" src="{vm>/logoSrc}" decorative="false" width="200px"/>
                        <Button
                            id="buttonBack1"
                            icon="sap-icon://nav-back"
                            press=".onNavBack" />
                    </contentLeft>
                    <contentMiddle>
                        <Title
                            id="title1"
                            text="Dati aggregati per fornitore" />
                    </contentMiddle>
                    <contentRight>
                        <HBox id="hbox2" width="200px"/>
                    </contentRight>
                </Bar>
            </Toolbar>
        </customHeader>

        <content>
            <!-- Filter bar: desktop=one row, mobile=2 rows -->
            <VBox id="vboxFilters1" class="mobileFilterBar">
                <HBox id="filterRow1A" alignItems="Center" class="filterRow">
                    <Label id="lblCatMat1" text="Categoria:" class="sapUiTinyMarginEnd"/>
                    <ComboBox
                        id="comboCatMat1"
                        width="250px"
                        placeholder="Tutte le categorie"
                        items="{vm>/userCategoriesList}"
                        selectionChange=".onFilterChanged">
                        <items>
                            <core:Item id="catItem1" key="{vm>key}" text="{vm>text}"/>
                        </items>
                    </ComboBox>
                    <Label id="labelOnlyIncomplete1" text="Solo dati incompleti" class="sapUiSmallMarginBegin sapUiTinyMarginEnd"/>
                    <Switch
                        id="switchOnlyIncomplete1"
                        state="true"
                        change=".onFilterChanged" />
                </HBox>
                <HBox id="filterRow1B" alignItems="Center" class="filterRow filterRowRight">
                    <Label id="labelVendorFilter1" text="Fornitore" class="sapUiTinyMarginEnd"/>
                    <SearchField
                        id="inputVendorFilter1"
                        width="15rem"
                        liveChange=".onFilterChanged"
                        search=".onFilterChanged"
                        placeholder="Cerca per nome o codice..." />
                </HBox>
            </VBox>

            <Table
                id="tableVendors1"
                mode="SingleSelectMaster"
                growing="true"
                growingThreshold="200"
                growingScrollToLoad="true"
                items="{
                    path: 'vm>/userVendors'
                }"
                itemPress=".onVendorPress">

                <headerToolbar>
                    <Toolbar id="toolbarTableHeader1">
                        <Title id="titleTable1" text="Fornitori" level="H2" />
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column id="columnVendor1">
                        <Text id="textColumnVendor1" text="Fornitore" />
                    </Column>
                    <Column id="columnOpenPo1" hAlign="Center">
                        <Text id="textColumnOpenPo1" text="Aperti" />
                    </Column>
                    <Column id="columnCatMat1" hAlign="Center">
                        <Text id="textColumnCatMat1" text="Cat. Materiale" />
                    </Column>
                    <Column id="columnToUnlock1" hAlign="Center">
                        <Text id="textColumnToUnlock1" text="Da sbloccare" />
                    </Column>
                    <Column id="columnRejected1" hAlign="Center">
                        <Text id="textColumnRejected1" text="Rifiutati" />
                    </Column>
                    <Column id="columnModified1" hAlign="Center">
                        <Text id="textColumnModified1" text="Modificati" />
                    </Column>
                    <Column id="columnPending1" hAlign="Center">
                        <Text id="textColumnPending1" text="In attesa approvazione" />
                    </Column>
                    <Column id="columnApproved1" hAlign="Center">
                        <Text id="textColumnApproved1" text="Approvati" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="columnListItemVendor1" type="Active">
                        <cells>
                            <ObjectIdentifier
                                id="objectIdentifierVendor1"
                                title="{vm>ReagSoc}"
                                text="{vm>Fornitore}" />

                            <core:Icon
                                id="iconOpen1"
                                src="{= ${vm>Open} === 'X' ? 'sap-icon://open-folder' : 'sap-icon://folder' }"
                                tooltip="{= ${vm>Open} === 'X' ? 'Aperti' : 'Nessun aperto' }" />

                            <Text
                                id="textCatMat1"
                                text="{vm>MatCatDesc}" />

                            <ObjectStatus
                                id="statusToUnlock1"
                                icon="sap-icon://locked"
                                text="{vm>ToUnlock}"
                                state="Warning" />

                            <ObjectNumber
                                id="objectNumberRejected1"
                                number="{vm>Rejected}"
                                state="Error" />

                            <ObjectNumber
                                id="objectNumberModified1"
                                number="{vm>Modified}"
                                state="Information" />

                            <ObjectNumber
                                id="objectNumberPending1"
                                number="{vm>ToApprove}"
                                state="Warning" />

                            <ObjectNumber
                                id="objectNumberApproved1"
                                number="{vm>Approved}"
                                state="Success" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
            <!-- Spacer pushes footer to bottom -->
            <VBox id="legalSpacer1" class="legalFooterSpacer"/>
            <!-- Legal Footer -->
            <VBox id="legalFooter1" class="appLegalFooter" alignItems="Center">
                <Text id="legalTitle1" text="VALENTINO.COM" class="legalFooterTitle"/>
                <Text id="legalCopy1" text="Powered by Valentino Copyright © {vm>/legalYear} VALENTINO S.p.A. - All rights reserved - VAT 05412951005 Informazioni sul venditore" class="legalFooterText"/>
           </VBox>
    </Page>
</mvc:View>