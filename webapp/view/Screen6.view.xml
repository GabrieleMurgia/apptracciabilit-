<mvc:View
  id="screen6View"
  controllerName="apptracciabilita.apptracciabilita.controller.Screen6"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:u="sap.ui.unified"
  xmlns:mdc="sap.ui.mdc"
  displayBlock="true"> 

  <Page id="page6" title="{i18n>screen6.pageTitle}" enableScrolling="false" class="sapUiNoContentPadding fullHeightPage pageWithLegalBar">

    <customHeader>
      <Toolbar id="toolbar6" class="appCustomHeader">
        <Bar id="bar6">
          <contentLeft>
            <Image id="imageLogo6" src="{vm>/logoSrc}" decorative="false" width="200px" class="hideLogo"/>
            <Button id="buttonBack6" icon="sap-icon://nav-back" press=".onNavBack" type="Transparent"/>
          </contentLeft>
          <contentMiddle>
            <Title id="title6" text="{i18n>screen6.headerTitle}" level="H3"/>
          </contentMiddle>
          <contentRight>
            <ToolbarSpacer id="bar6SpacerRight"/>
          </contentRight>
        </Bar>
      </Toolbar>
    </customHeader>

    <content>

      <!-- Filter bar: desktop=one row, mobile=2 rows -->
      <VBox id="vboxFilters6" class="mobileFilterBar">
        <HBox id="filterRow6A" alignItems="Center" class="filterRow">
          <Label id="lblCatMat6" text="{i18n>common.categoryMaterialLabel}" class="sapUiTinyMarginEnd"/>
          <ComboBox
            id="comboCatMat6"
            width="250px"
            placeholder="{i18n>common.categoryPlaceholder}"
            items="{vm>/userCategoriesList}"
            selectedKey="{detail>/selectedCat}">
            <items>
              <core:Item id="catItem6" key="{vm>key}" text="{vm>text}"/>
            </items>
          </ComboBox>
          <Button
            id="btnDownloadTemplate6"
            text="{i18n>screen6.downloadTemplate}"
            icon="sap-icon://download"
            type="Emphasized"
            press=".onDownloadTemplate"
            class="sapUiSmallMarginBegin"/>
          <Button
            id="btnDownloadMaterials6"
            text="{i18n>screen6.downloadMaterialList}"
            icon="sap-icon://excel-attachment"
            type="Default"
            press=".onDownloadMaterialList"
            class="sapUiSmallMarginBegin"/>
        </HBox>
        <HBox id="filterRow6B" alignItems="Center" class="filterRow">
          <u:FileUploader
            id="fileUploader6"
            name="excelUpload"
            fileType="xlsx,xls"
            placeholder="{i18n>screen6.uploadPlaceholder}"
            width="350px"
            change=".onFileSelected"
            buttonText="{i18n>common.chooseFile}"/>
          <ObjectStatus
            id="osRowCount6"
            text="{= ${i18n>screen6.loadedRowsLabel} + ': ' + (${detail>/RowsCount} || 0) }"
            state="None"
            class="sapUiSmallMarginBegin"/>
          <ObjectStatus
            id="osCheckStatus6"
            visible="{detail>/checkDone}"
            text="{= ${detail>/checkErrorCount} === 0 ? ${i18n>screen6.checkOk} : (${i18n>screen6.errorsLabel} + ': ' + ${detail>/checkErrorCount}) }"
            state="{= ${detail>/checkErrorCount} === 0 ? 'Success' : 'Error' }"
            icon="{= ${detail>/checkErrorCount} === 0 ? 'sap-icon://status-completed' : 'sap-icon://alert' }"
            class="sapUiSmallMarginBegin"/>
        </HBox>
      </VBox>

      <!-- Filters toolbar -->
      <HBox
        id="hboxToolbarTable6"
        width="100%"
        justifyContent="SpaceBetween"
        alignItems="Center"
        class="tableControlBar"
        wrap="Wrap">

        <HBox id="hboxToolbarTable6-1" wrap="Wrap" alignItems="Center" class="filterGroup">
          <HBox id="hboxFilter6" alignItems="Center" class="searchFilterBox">
            <Label id="lblFilter6" text="{i18n>common.searchLabel}" labelFor="inputFilter6" class="sapUiTinyMarginEnd filterLabel"/>
            <Input id="inputFilter6" width="100%" liveChange=".onGlobalFilter" placeholder="{i18n>common.searchAllFieldsPlaceholder}" class="searchInput"/>
            <Button id="btnColFilters6" icon="sap-icon://filter" tooltip="{i18n>common.columnFiltersTooltip}" press=".onOpenColumnFilters" type="Transparent"/>
            <Button id="btnSort6" icon="sap-icon://sort" tooltip="{i18n>common.sortTooltip}" press=".onOpenSort" type="Transparent"/>
            <Button id="btnResetFS6" icon="sap-icon://reset" tooltip="{i18n>common.resetFiltersTooltip}" press=".onResetFiltersAndSort" type="Transparent"/>
          </HBox>
        </HBox>

        <Toolbar id="tblToolbar6" design="Transparent" class="actionToolbar">
          <ToolbarSpacer id="footerToolbar6sp"/>
          <Button id="btnClearUpload6" text="{i18n>common.clear}" icon="sap-icon://delete" type="Default" press=".onClearUpload"/>
          <Button id="tbExcel6" icon="sap-icon://excel-attachment" tooltip="{i18n>screen6.exportPreviewTooltip}" press=".onExportExcel" type="Transparent"/>
        </Toolbar>

      </HBox>

      <!-- MDC Table: preview uploaded data -->
      <mdc:Table
        id="mdcTable6"
        type="Table"
        width="100%"
        height="100%"
        selectionMode="None"
        p13nMode="Column"
        class="fullSizeTable"
        delegate='{
          "name":"apptracciabilita/apptracciabilita/delegates/MdcGenericTableDelegate",
          "payload":{
            "cfgModel":"vm",
            "cfgPath":"/mdcCfg/screen6",
            "defaultModel":"detail",
            "defaultPath":"/Rows"
          }
        }'>
      </mdc:Table>

    </content>

    <footer>
      <OverflowToolbar id="footerToolbar6">
        <ToolbarSpacer id="footerSpacer6"/>
        <Button
          id="btnSendData6"
          text="{i18n>common.sendData}"
          icon="sap-icon://upload-to-cloud"
          type="Emphasized"
          enabled="{= ${detail>/RowsCount} > 0 &amp;&amp; ${detail>/checkDone} === true &amp;&amp; ${detail>/checkErrorCount} === 0 }"
          press=".onSendData"/>
      </OverflowToolbar>
    </footer>

  </Page>
</mvc:View>
