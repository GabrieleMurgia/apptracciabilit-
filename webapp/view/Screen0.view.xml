<mvc:View
    id="screen0View"
    controllerName="apptracciabilita.apptracciabilita.controller.Screen0"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        id="page0"
        title="{i18n>screen0.pageTitle}">
        <customHeader>
            <Toolbar id="toolbar0">

        <Bar id="bar0">
            <contentLeft>
            <!-- <Image id="imageLogo0" src="IMG/Valentino.png" decorative="false" width="200px"/> -->
            <Image id="imageLogo0" src="{vm>/logoSrc}" decorative="false" width="200px"/>

            </contentLeft>

        <contentMiddle>
            <Title id="title0" text="{i18n>screen0.headerTitle}" textAlign="Center"/>
        </contentMiddle>

        <contentRight>
            <HBox id ="hbox1" width="200px"/>
        </contentRight>
        </Bar>

            </Toolbar>
        </customHeader>

        <content>
            <VBox
                id="vbox0"
                width="100%"
                justifyContent="Center"
                alignItems="Center"
                renderType="Div">
                <Text
                    id="textIntro0"
                    text="{i18n>screen0.intro}"
                    textAlign="Center"
                    class="FirstTitle"
                     />

                <HBox
                    id="hboxTiles0"
                    class="tilesContainer"
                    justifyContent="Center"
                    alignItems="Start"
                    width="100%">
                    <!-- Flusso A: Dati aggregati -->
                    <GenericTile
                        width="100%"
                        id="tileFlowA"
                        header="{i18n>screen0.tileFlowAHeader}"
                        subheader="{i18n>screen0.tileFlowASubheader}"
                        press="onPressFlowA">
                        <tileContent>
                            <TileContent id="tileContentA">
                                <content>
                                    <core:Icon
                                        id="iconFlowA"
                                        src="sap-icon://combine"
                                        size="3rem" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <!-- Flusso B: Carica da Excel -->
                    <GenericTile
                        width="100%"
                        id="tileFlowB"
                        header="{i18n>screen0.tileFlowBHeader}"
                        subheader="{i18n>screen0.tileFlowBSubheader}"
                        press="onPressFlowB">
                        <tileContent>
                            <TileContent id="tileContentB">
                                <content>
                                    <core:Icon
                                        id="iconFlowB"
                                        src="sap-icon://excel-attachment"
                                        size="3rem" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <!-- Flusso C: Dati in tabella -->
                    <GenericTile
                        width="100%"
                        id="tileFlowC"
                        visible="{vm>/showAggregatedTile}"
                        header="{i18n>screen0.tileFlowCHeader}"
                        subheader="{i18n>screen0.tileFlowCSubheader}"
                        press="onPressFlowC">
                        <tileContent>
                            <TileContent id="tileContentC">
                                <content>
                                    <core:Icon
                                        id="iconFlowC"
                                        src="sap-icon://table-view"
                                        size="3rem" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>
                </HBox>
            </VBox>
                                        <!-- Spacer pushes footer to bottom -->
            <VBox id="legalSpacer0" class="legalFooterSpacer"/>
            <!-- Legal Footer -->
            <VBox id="legalFooter0" class="appLegalFooter" alignItems="Center">
                <Text id="legalTitle0" text="{i18n>legal.site}" class="legalFooterTitle"/>
<Text id="legalCopy0" text="{= ${i18n>legal.copyPrefix} + ${vm>/legalYear} + ${i18n>legal.copySuffix} }" class="legalFooterText"/>
</VBox>
        </content>

    </Page>
</mvc:View>
